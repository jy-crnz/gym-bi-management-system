datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client" 
}

// 🏛️ NEW: Replaced arbitrary Tiers with exact Business Offerings
enum PassType {
  DAY_PASS
  MONTHLY
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

// DIMENSION: Member Profile (The "Who")
model Member {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  status          MemberStatus  @default(ACTIVE)
  
  // 🏛️ NEW: Real-world Access & Billing Control
  passType        PassType      @default(DAY_PASS)
  activeUntil     DateTime?     // The exact moment their pass or month expires
  
  // BI Enrichment Fields
  churnRiskScore  Float         @default(0.0) 
  totalSpent      Decimal       @default(0)
  
  attendance      Attendance[]
  transactions    Transaction[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// FACT: Attendance Logs (The "Behavior")
model Attendance {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id])
  
  checkIn   DateTime  @default(now())
  checkOut  DateTime?
  location  String    @default("Main Floor")
  
  createdAt DateTime  @default(now())
}

// FACT: Transactions (The "Value")
model Transaction {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id])
  amount    Decimal
  type      String    // Will now be explicitly "Day Pass" or "Monthly Renewal"
  
  createdAt DateTime  @default(now())
}

model SystemSettings {
  id           String   @id @default("settings")
  revenueGoal  Decimal  @default(50000)
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "MEMBER_DELETE", "GOAL_UPDATE", "STATUS_CHANGE"
  entityId  String?  // The ID of the member or setting changed
  details   String   // A human-readable description of what happened
  adminName String   // Who did it (can be hardcoded for now or from your auth)
  createdAt DateTime @default(now())
}